{
  "name": "italian-brainrot",
  "version": "0.1.0",
  "private": true,
  "description": "Italian Brainrot 主题的 3v3 D&D 回合制战斗游戏（8 年前 C++/Qt 课程作业的现代化重写）",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:client": "npm run dev --workspace packages/client",
    "dev:server": "npm run dev --workspace packages/server",
    "sim": "tsx packages/shared/src/sim.cli.ts",
    "sim:balance": "tsx packages/shared/src/sim.cli.ts balance",
    "art": "node art/process.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tsx": "^4.22.4"
  }
}
