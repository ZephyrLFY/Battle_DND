{
  "name": "battle-pokemon",
  "version": "0.1.0",
  "private": true,
  "description": "Web rewrite of an 8-year-old C++/Qt Pokemon battle game",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:client": "npm run dev --workspace packages/client",
    "dev:server": "npm run dev --workspace packages/server",
    "sim": "tsx packages/shared/src/sim.cli.ts",
    "art": "node art/process.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "tsx": "^4.22.4"
  }
}
